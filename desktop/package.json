{
  "name": "corral-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "Corral Electron shell — wraps the headless control plane in a desktop app (BYOK keychain, setup wizard).",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.corral.app",
    "productName": "Corral",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer"
      },
      {
        "from": "../dist",
        "to": "core/dist"
      },
      {
        "from": "../WORKFLOW.md",
        "to": "core/WORKFLOW.md"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "build/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jung519",
        "repo": "corral",
        "releaseType": "draft"
      }
    ]
  }
}
