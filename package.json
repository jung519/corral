{
  "name": "corral",
  "version": "0.0.0",
  "description": "Open-source agent development orchestrator — tracker → repo → human approval → AI coding agent. BYOK, provider-neutral, self-hostable.",
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:renderer": "pnpm -C renderer build",
    "build:desktop": "pnpm -C desktop build",
    "build:all": "pnpm build && pnpm build:renderer && pnpm build:desktop",
    "package": "pnpm build:all && pnpm -C desktop dist",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "liquidjs": "^10.19.0",
    "marked": "^18.0.5",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.10.0"
}
